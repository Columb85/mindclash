# ══════════════════════════════════════════════════════════════════════════════
# MindClash Backend API - Production Environment
# Copy this file to .env on your server and fill in the values
# ══════════════════════════════════════════════════════════════════════════════

PORT=4000
NODE_ENV=production
DB_FILE=mindclash.db

# Mantle Sepolia Network
CHAIN_ID=5003
RPC_URL=https://rpc.sepolia.mantle.xyz
EXPLORER_URL=https://sepolia.mantlescan.xyz

# Deployed Contract Addresses
AGENT_NFT_ADDRESS=0xEEc82Ecd81d889D7f1681741cfC1Fc1B7eC4B837
AGENT_REGISTRY_ADDRESS=0xbD19d3ec1B4d0f3852729b0dcC87bd739839cBDC
ROUND_ENGINE_ADDRESS=0x69656D3220fDF9F59F005b0D73834D6af2E9cf9a
TREASURY_ADDRESS=0xA82615C3882170BAFCFb145C19B2D388E7aF5952
CLASH_TOKEN_ADDRESS=0xFb178c931e5F64bBA180A4419E4E2f216d1eEDDe
ORACLE_ADAPTER_ADDRESS=0x246CD1fcdF43dDfF09b7619375bD4E8C98ECa612

# Read-only by default — duels return AI decisions without signing txs.
# Live on-chain duels: https://api.mindclash.xyz
ENABLE_ONCHAIN_SIGNING=false

# Optional: only if ENABLE_ONCHAIN_SIGNING=true (use YOUR testnet wallet)
# AGENT_PRIVATE_KEY=your_testnet_private_key_here
# AGENT_ALPHA_PRIVATE_KEY=
# AGENT_MOMENTUM_PRIVATE_KEY=
# AGENT_NEURAL_PRIVATE_KEY=

# Bybit API
BYBIT_WS_URL=wss://stream.bybit.com/v5/public/linear
BYBIT_REST_URL=https://api.bybit.com/v5/market/tickers

# CORS - frontend origin (api.mindclash.xyz serves the backend, mindclash.xyz is the frontend)
CORS_ORIGIN=https://mindclash.xyz

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# ── Neural / LLM decision engine (optional) ───────────────────────────────────
# NEURAL_PROVIDER=rules          # rules | openai | groq  (default: rules)
# NEURAL_MODEL=gpt-4o-mini       # or llama-3.3-70b-versatile for Groq
# OPENAI_API_KEY=sk-...
# GROQ_API_KEY=gsk_...
# NEURAL_ALL_STRATEGIES=false    # true = LLM for all 3 bots, not just neural

# Max user-created agents per wallet (default 1, matches on-chain AgentNFT rule)
MAX_AGENTS_PER_WALLET=1
